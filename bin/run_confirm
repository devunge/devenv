#!/usr/bin/env bash

ROFI_THEME="$HOME/.config/rofi/launcher.rasi"

ROFI_OPTIONS=(
  -dmenu
  -i
  -mesg "$1"
  -theme-str 'window {width: 400px; location: north; anchor: north;}'
  -theme-str 'listview {lines: 2; scrollbar: false;}'
  -theme-str 'element-text {horizontal-align: 0;}'
  -theme-str 'inputbar {enabled:false;} prompt {enabled:false;}'
)
# Adiciona tema personalizado se existir
if [[ -f "$ROFI_THEME" ]]; then
  ROFI_OPTIONS+=(-theme "$ROFI_THEME")
fi

ans=$(printf "Yes\nNo" | rofi "${ROFI_OPTIONS[@]}")

if [[ "$ans" == "Yes" ]]; then
  exit 0
else
  exit 1
fi
