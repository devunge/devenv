#!/usr/bin/env bash

ROFI_THEME="$HOME/.config/rofi/launcher.rasi"

ROFI_OPTIONS=(
  -dmenu
  -i
  -p "$1:"
  -theme-str 'window {width: 400px;}'
  -theme-str 'listview {lines: -1; scrollbar: true;}'
  -theme-str 'element-text {horizontal-align: 0;}'
)
# Adiciona tema personalizado se existir
if [[ -f "$ROFI_THEME" ]]; then
  ROFI_OPTIONS+=(-theme "$ROFI_THEME")
fi

rofi "${ROFI_OPTIONS[@]}"
